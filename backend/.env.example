# Локальная разработка
DATABASE_URL=sqlite:///./railway.db
STORAGE_BACKEND=local
USE_TASK_QUEUE=false
AUTH_REQUIRED=false
ENCRYPT_TRANSCRIPTS=false

# ASR (FR 15.1): faster-whisper | yandex
ASR_PROVIDER=faster-whisper
WHISPER_MODEL=base
WHISPER_DEVICE=cpu

# LLM (FR 15.2–15.3): текст → строгий JSON, не Excel
PARSER_MODE=hybrid
LLM_PRIMARY_PARSER=openai
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
LLM_REVIEW_DISPUTED=true

# Yandex SpeechKit (если ASR_PROVIDER=yandex)
# YANDEX_SPEECH_API_KEY=
# YANDEX_SPEECH_FOLDER_ID=

# ── Supabase + Vercel (см. backend/.env.cloud.example и docs/DEPLOY_SUPABASE_VERCEL.md) ──
# DATABASE_URL=postgresql://postgres.[ref]:[pass]@....pooler.supabase.com:6543/postgres
# STORAGE_BACKEND=supabase
# SUPABASE_URL=https://[ref].supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# VERCEL_URL=https://your-app.vercel.app

# ── Production (Docker) ──
# DATABASE_URL=postgresql://railway:pass@postgres:5432/railway
# STORAGE_BACKEND=s3
# S3_ENDPOINT=http://minio:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# USE_TASK_QUEUE=true
# REDIS_URL=redis://redis:6379/0
# AUTH_REQUIRED=true
# SECRET_KEY=
# DATA_ENCRYPTION_KEY=
