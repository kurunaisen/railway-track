# Supabase + Vercel + Railway (облачный production)
# Скопируйте в backend/.env на Railway и заполните значения

# ── Supabase Postgres (Settings → Database → Connection string → URI, pooler :6543) ──
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# ── Supabase Storage ──
STORAGE_BACKEND=supabase
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_STORAGE_BUCKET=audio

# ── Yandex SpeechKit (ASR, обязательно в облаке — без Whisper) ──
ASR_PROVIDER=yandex
YANDEX_SPEECH_API_KEY=
YANDEX_SPEECH_FOLDER_ID=

# ── ChatGPT (LLM) ──
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini

# ── Безопасность ──
AUTH_REQUIRED=true
SECRET_KEY=          # openssl rand -hex 32
ENCRYPT_TRANSCRIPTS=true
DATA_ENCRYPTION_KEY= # openssl rand -hex 32

# ── CORS: URL фронтенда на Vercel ──
VERCEL_URL=https://your-app.vercel.app
CORS_ORIGINS=["https://your-app.vercel.app"]

# ── Очередь (опционально: Upstash Redis) ──
USE_TASK_QUEUE=false
# USE_TASK_QUEUE=true
# REDIS_URL=rediss://default:...@...upstash.io:6379

TRUST_PROXY_HEADERS=true
MAX_UPLOAD_MB=100
